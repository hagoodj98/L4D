<!DOCTYPE html>
<html>
    <head>
        <title>Register Here</title>
        <%- include("partials/header.ejs") %>
                    <% if (locals.currentUser) { %>
                      <li class="nav-item ">
                        <a class="nav-link roboto-condensed "  href="/logout" >
                          Welcome <%- currentUser %>, Logout?
                        </a>
                       </li>
                    <% } else {%>
                        <li class="nav-item dropdown">
                            <a class="nav-link roboto-condensed "  href="/login" >
                              Login
                            </a>
                            </li>
                    <% } %>
                     
                  </ul>
                </div>
              </div>
            </div>
          </nav>
    <div class=" d-flex flex-column justify-content-center  align-items-center" style="background-color: black;  height: 100vh;">
      <div class="formwidth">
          <form class="login" action="/register"  method="POST" >
            <h3 class="bungee-regular formtitle text-center" style="color: white;">Get Registered!</h3>
              <div class="mb-3">
                  <label class="roboto-condensed" style="color: white;" for="email">Email</label>
                  <input type="email" class="form-control"  placeholder="Email"  name="email" required>
                  <span style="color: red;"><%- locals.error %></span>
              </div>
              <div class="mb-3">
                <label class="roboto-condensed" style="color: white;" for="username">Username</label>
                  <input type="text" placeholder="Username" name="username" id="username" required class="form-control" >
              </div>
              <div class="mb-3">
                <label class="roboto-condensed" style="color: white;" for="password">Password</label>
                  <input type="password" name="password" placeholder="Password" id="password" required class="form-control" >
              </div>
              <p class=""> <a class="linkbelowlogins roboto-condensed"  style=" text-decoration: none;" href="/login" role="button">Remember? Then Login!</a></p>
              
              <button type="submit" class="  btn btn-dark roboto-condensed">Register</button>
          </form>
      </div>
  </div>
 