            </div>
            <div class="topspacingforum">
                <div class="forumsubheaders">
                    <h2 style="color: #ffffff;"  class="roboto-condensed">Share Infected Advice</h2>
                </div>
                <div id="shareadvice" class="forumsections " style="height: 300px;" >
                    <a href="/login"  > 
                        
                        <div class="overlay d-flex justify-content-center align-items-center">
                            <div >
                                Anything on your mind?<br> <span class="greenselected">Need some advice</span> <br>about the Left 4 Dead?
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
