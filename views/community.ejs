<%- include("partials/header.ejs") %>
<div>
  <div class="container-fluid headers" id="community">
    <div
      class="d-flex gap-3 flex-column-reverse flex-lg-row-reverse container align-items-lg-center"
    >
      <div class="headertext d-flex align-items-center p-3">
        <div>
          <h1 class="bungee-regular" style="color: #ffffff">
            Your <span style="color: #d83232">Community</span>
          </h1>
          <a href="#anchor4"
            ><button class="btn learnmore">Learn more</button></a
          >
        </div>
      </div>
    </div>
  </div>

  <div class="container d-flex flex-column">
    <div
      id="forum"
      class="d-flex container divspacing flex-column align-items-md-start justify-content-center"
    >
      <div id="anchor4">
        <h2 style="color: #ffffff" class="roboto-condensed">Community Hub</h2>
      </div>
      <div>
        <p style="color: white">
          Everything for Left 4 Dead fans in one place. Keep up with official
          updates, find teammates for your next run, and jump into gameplay
          discussions with other survivors.
        </p>
        <p style="color: rgba(255, 255, 255, 0.78)">
          Use the sections below to move fast: check patch notes, squad up on
          Discord, or share practical tips for campaigns, specials, and weapon
          loadouts.
        </p>
      </div>
    </div>
    <div class="d-flex justify-content-center" style="width: 100%">
      <div class="topspacingforum">
        <div class="forumsubheaders">
          <h2 style="color: #ffffff" class="roboto-condensed">
            Latest Updates
          </h2>
        </div>
        <div id="news" class="forumsections" style="height: 300px">
          <a href="https://www.l4d.com/blog/">
            <div
              class="overlay d-flex justify-content-center align-items-center"
            >
              <div>
                <span class="greenselected">Read patch notes</span><br />
                and official Left 4 Dead news
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
    <div
      class="d-flex flex-column align-items-center align-items-md-start flex-md-row gap-3 row-gap-3"
    >
      <div class="topspacingforum">
        <div class="forumsubheaders">
          <h2 style="color: #ffffff" class="roboto-condensed">Find a Squad</h2>
        </div>
        <div id="findsquad" class="forumsections" style="height: 300px">
          <a href="https://discord.com/invite/l4d2">
            <div
              class="overlay d-flex justify-content-center align-items-center"
            >
              <div>
                <span class="greenselected">Find a team</span><br />
                for campaigns, versus, and survival
              </div>
            </div>
          </a>
        </div>
      </div>
      <div class="topspacingforum">
        <div class="forumsubheaders">
          <h2 style="color: #ffffff" class="roboto-condensed">
            Ask & Share Strategy
          </h2>
        </div>
        <div id="shareadvice" class="forumsections" style="height: 300px">
          <a href="/login">
            <div
              class="overlay d-flex justify-content-center align-items-center"
            >
              <div>
                Post your question, route, or build idea.<br />
                <span class="greenselected">Get practical advice</span><br />
                from other players
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("partials/footer.ejs") %>
