<!DOCTYPE html>
<html>
  <head>
    <title>ZombieSlayers</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bungee&family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
    />
    <link rel="stylesheet" type="text/css" href="/css/reset.css" />
    <link rel="stylesheet" type="text/css" href="/css/styles.css" />
  </head>
  
  <body
    style="background-color: black; "
    class="<%= currentPath === '/forum' ? 'forum-page' : '' %>"

  >

    <nav class="navbar navbar-expand-lg fixed-top site-navbar">
      <div class="container-fluid">
        <a class="navbar-brand" href="/"
          ><img
            src="/images/110623bcd586fd570536803d7413fc13 1.png"
            width="200px"
            class="img-fluid"
            alt=""
        /></a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="offcanvas"
          data-bs-target="#offcanvasNavbar"
          aria-controls="offcanvasNavbar"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div
          class="offcanvas offcanvas-end site-offcanvas"
          style="background-color: #0d0d0d"
          tabindex="-1"
          id="offcanvasNavbar"
          aria-labelledby="offcanvasNavbarLabel"
        >
          <div class="offcanvas-header">
            <h5
              class="offcanvas-title bungee-regular"
              style="color: white"
              id="offcanvasNavbarLabel"
            >
              ZombieSlayers
            </h5>
            <button
              type="button"
              class="btn-close btn-close-white"
              data-bs-dismiss="offcanvas"
              aria-label="Close"
            ></button>
          </div>
          <div class="offcanvas-body">
            <ul class="navbar-nav justify-content-end flex-grow-1 pe-3 site-nav-list">
              <li class="nav-item">
                <a
                  class="nav-link roboto-condensed"
                  aria-current="page"
                  href="/"
                  >Home</a
                >
              </li>
              <li class="nav-item">
                <a class="nav-link roboto-condensed" href="/survivors"
                  >Survivors</a
                >
              </li>
              <li class="nav-item">
                <a class="nav-link roboto-condensed" href="/specialinfected"
                  >Special Infected</a
                >
              </li>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle roboto-condensed" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Community
                </a>
                <ul class="dropdown-menu dropdown-menu-end site-dropdown-menu" >
                  <li><a class="dropdown-item" href="/community">Get Connected</a></li>
                  <li><a class="dropdown-item" href="/forum">Forum</a></li>
                </ul>
              </li>
               
              <% if (locals.user) { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle roboto-condensed" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                  </svg>
                 </span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end site-dropdown-menu" >
                  <span class="text-white">Profile,</span>
                  <p class="text-white"><%= locals.user %></p>
                  <li class="nav-item"> <a class="nav-link roboto-condensed" href="/logout"
                  > Logout</a
                ></li>
                </ul>
              </li>
              <% } else { %>
              <li class="nav-item">
                <a class="nav-link roboto-condensed" href="/login"
                  >Login</a
                >
              </li>
              <% } %>
            </ul>
          </div>
        </div>
      </div>
    </nav>
