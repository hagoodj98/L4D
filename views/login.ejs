<%- include("partials/header.ejs") %>

<div class="auth-scene">
  <div
    class="container auth-shell d-flex flex-column flex-lg-row gap-4 align-items-stretch justify-content-center"
  >
    <section
      class="auth-brand-panel d-none d-lg-flex flex-column justify-content-center"
    >
      <h2 class="bungee-regular auth-brand-name">ZombieSlayers</h2>

      <p class="roboto-condensed auth-brand-copy">
        Squad up with the community, track your progress, and stay ready for
        every campaign.
      </p>
    </section>

    <section class="auth-card">
      <h3 class="roboto-condensed auth-card-title">Welcome back</h3>
      <p class="auth-card-subtitle roboto-condensed">
        Sign in to ZombieSlayers
      </p>

      <div class="auth-social-stack mb-3">
        <a href="/auth/google" class="btn btn-light auth-social-btn"
          >Continue with Google</a
        >
        <a href="/auth/twitch" class="btn btn-light auth-social-btn"
          >Continue with Twitch</a
        >
        <a href="/auth/discord" class="btn btn-light auth-social-btn"
          >Continue with Discord</a
        >
      </div>

      <div class="auth-divider roboto-condensed mb-3">
        or continue with account
      </div>

      <form class="auth-form" action="/login" method="POST">
        <div class="mb-3">
          <label class="roboto-condensed auth-label" for="username"
            >Username</label
          >
          <input
            type="text"
            class="form-control auth-input"
            name="username"
            placeholder="Username"
            required
            id="username"
          />
          <span class="auth-error"
            ><%= locals.error && locals.error.username ? locals.error.username :
            "" %></span
          >
          <span class="auth-error"
            ><% if (locals.error) { %><%= locals.error === "User not found" ?
            "User not found" : "" %><% } %></span
          >
        </div>

        <div class="mb-3">
          <label class="roboto-condensed auth-label" for="password"
            >Password</label
          >
          <input
            type="password"
            name="password"
            id="password"
            required
            class="form-control auth-input"
            placeholder="Enter Password"
          />
          <span class="auth-error"
            ><%= locals.error && locals.error.password ? locals.error.password :
            "" %></span
          >
          <span class="auth-error"
            ><% if (locals.error) { %><%= locals.error === "Invalid password" ?
            "Incorrect password" : "" %><% } %></span
          >
        </div>

        <button
          type="submit"
          class="btn auth-primary-btn roboto-condensed w-100"
        >
          Sign in
        </button>

        <p class="auth-bottom-link roboto-condensed text-center mt-3">
          New here?
          <a href="/register">Create an account</a>
        </p>
      </form>
    </section>
  </div>
</div>

<%- include("partials/footer.ejs") %>
